# pawffinated.env – Database connection config for Pawffinated
# =============================================================
# Place this file in the same directory as db_connection.py.
# Never commit this file to version control (add it to .gitignore).
#
# Choose ONE of the two options below and fill in your details.
# ─────────────────────────────────────────────────────────────
 
# OPTION A — Full DSN (simplest, one line)
# Uncomment and fill in:
# DATABASE_URL = postgresql://pawff_user:"1234"@localhost:5432/pawffinated
 
OPTION B — Individual keys
DB_HOST = localhost
DB_PORT = 5432
DB_NAME = pawffinated
DB_USER = pawff_user
DB_PASS = 1234

# ── Notes ──────────────────────────────────────────────────────
# • If DATABASE_URL is set, the individual DB_* keys are ignored.
# • Any key already set in the environment beats what's in this file,
#   so you can always override with:
#       DATABASE_URL=postgresql://... python pawffinated_inventory_qt.py
# • Inline comments are supported: DB_PORT = 5432  # default pg port
# • Surrounding quotes are stripped:  DB_PASS = "my secret"  is fine.